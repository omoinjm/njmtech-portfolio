# Site Configuration
NEXT_PUBLIC_SITE_URL="https://njmtech.vercel.app"

# Email Configuration (server-only — do NOT prefix with NEXT_PUBLIC_)
EMAIL_MAIL="your-email@example.com"
EMAIL_APP_PASS="your-app-specific-password"
EMAIL_USER="your-email@example.com"

# Mailchimp Newsletter Integration
NEXT_PUBLIC_MAILCHIMP_URL="https://your-mailchimp-list.list-manage.com/subscribe/post?..."

# Database Configuration (Cloudflare D1)
D1_ACCOUNT_ID="your-cloudflare-account-id"
D1_DATABASE_ID="your-d1-database-id"
D1_API_TOKEN="your-cloudflare-api-token"

# AI Configuration
# Get your GitHub Personal Access Token with 'models:read' scope
GITHUB_TOKEN="your-github-pat-token"
GEMINI_API_KEY="your-gemini-api-key"

# VoxCPM TTS (High Quality AI Voice Design/Cloning)
# Hugging Face Token for API access (recommended to avoid rate limits)
HF_TOKEN="your-huggingface-token"
# Reference audio URL for cloning (optional)
VOXCPM_REF_AUDIO="https://example.com/omoi-voice-ref.wav"
# Description of the voice if no ref audio is used
VOXCPM_VOICE_INSTRUCTION="A young male voice with a clear but anxious and overthinking tone. Nervous energy."
